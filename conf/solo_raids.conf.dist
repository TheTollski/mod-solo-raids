#
# mod-solo-raids
#
# Copy this file to solo_raids.conf and restart or reload config.
#

#
# Blackwing Lair
#

# Remove Razorgore's Destroy Egg cooldown in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Razorgore.DestroyEgg.ClearCooldown = 1

# Razorgore Destroy Egg cast time as a percentage of normal while controlled in solo Blackwing Lair.
# 0.5 means 50% of the normal cast time.
# Default: 0.5
SoloRaids.BlackwingLair.Razorgore.DestroyEgg.CastSpeedPct = 0.5

# Disable Vaelastrasz's Burning Adrenaline in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Vaelastrasz.DisableBurningAdrenaline = 1

# Shadow of Ebonroc duration in milliseconds in solo Blackwing Lair.
# Default: 2000
SoloRaids.BlackwingLair.Ebonroc.ShadowOfEbonroc.DurationMs = 2000

# Disable Chromaggus's Time Lapse in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Chromaggus.DisableTimeLapse = 1

#
# Temple of Ahn'Qiraj
#

# Disable Twin Emperors' Heal Brother in solo Temple of Ahn'Qiraj.
# Default: 1
SoloRaids.TempleOfAhnQiraj.TwinEmperors.DisableHealBrother = 1

#
# Naxxramas
#

# Patchwerk Hateful Strike damage percentage against the solo player.
# 0.5 means 50% of normal damage.
# Default: 0.5
SoloRaids.Naxxramas.Patchwerk.HatefulStrike.DamagePct = 0.5

# Disable Gluth's zombie healing in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Gluth.DisableZombieHealing = 1

# Maximum Mortal Wound stacks on the solo player during Gluth in solo Naxxramas.
# Default: 3
SoloRaids.Naxxramas.Gluth.MortalWound.MaxStacks = 3

# Gluth Enrage duration percentage in solo Naxxramas.
# 0.5 means 50% of normal duration.
# Default: 0.5
SoloRaids.Naxxramas.Gluth.Enrage.DurationPct = 0.5

# Disable Feugen's Static Field mana drain in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Thaddius.DisableStaticFieldManaDrain = 1

# Disable Instructor Razuvious's Mana Burn in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Razuvious.DisableManaBurn = 1

# Instructor Razuvious Unbalancing Strike damage percentage against the solo player.
# 0.5 means 50% of normal damage.
# Default: 0.5
SoloRaids.Naxxramas.Razuvious.UnbalancingStrike.DamagePct = 0.5

# Maximum active Guardian of Icecrown spawns during Kel'Thuzad in solo Naxxramas.
# Default: 2
SoloRaids.Naxxramas.KelThuzad.GuardianOfIcecrown.MaxActive = 2
