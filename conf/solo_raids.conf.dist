#
# mod-solo-raids
#
# Copy this file to solo_raids.conf and restart or reload config.
#

# TBC Dungeons
# -----------------------------------------------------------------------------

#
# Black Morass
#

# Disable Temporus's Hasten in solo Black Morass.
# Default: 1
SoloRaids.BlackMorass.Temporus.DisableHasten = 1

# Disable Aeonus's Thrash in solo Black Morass.
# Default: 1
SoloRaids.BlackMorass.Aeonus.DisableThrash = 1

# Raids
# -----------------------------------------------------------------------------

#
# Blackwing Lair
#

# Remove Razorgore's Destroy Egg cooldown in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Razorgore.DestroyEgg.ClearCooldown = 1

# Razorgore Destroy Egg cast time as a percentage of normal while controlled in solo Blackwing Lair.
# 0.5 means 50% of the normal cast time.
# Default: 0.5
SoloRaids.BlackwingLair.Razorgore.DestroyEgg.CastSpeedPct = 0.5

# Disable Vaelastrasz's Burning Adrenaline in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Vaelastrasz.DisableBurningAdrenaline = 1

# Shadow of Ebonroc duration in milliseconds in solo Blackwing Lair.
# Default: 2000
SoloRaids.BlackwingLair.Ebonroc.ShadowOfEbonroc.DurationMs = 2000

# Disable Chromaggus's Time Lapse in solo Blackwing Lair.
# Default: 1
SoloRaids.BlackwingLair.Chromaggus.DisableTimeLapse = 1

#
# Temple of Ahn'Qiraj
#

# Disable Twin Emperors' Heal Brother in solo Temple of Ahn'Qiraj.
# Default: 1
SoloRaids.TempleOfAhnQiraj.TwinEmperors.DisableHealBrother = 1

#
# Naxxramas
#

# Patchwerk Hateful Strike damage percentage against the solo player.
# 0.5 means 50% of normal damage.
# Default: 0.5
SoloRaids.Naxxramas.Patchwerk.HatefulStrike.DamagePct = 0.5

# Disable Gluth's zombie healing in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Gluth.DisableZombieHealing = 1

# Maximum Mortal Wound stacks on the solo player during Gluth in solo Naxxramas.
# Default: 3
SoloRaids.Naxxramas.Gluth.MortalWound.MaxStacks = 3

# Gluth Enrage duration percentage in solo Naxxramas.
# 0.5 means 50% of normal duration.
# Default: 0.5
SoloRaids.Naxxramas.Gluth.Enrage.DurationPct = 0.5

# Disable Feugen's Static Field mana drain in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Thaddius.DisableStaticFieldManaDrain = 1

# Disable Instructor Razuvious's Mana Burn in solo Naxxramas.
# Default: 1
SoloRaids.Naxxramas.Razuvious.DisableManaBurn = 1

# Instructor Razuvious Unbalancing Strike damage percentage against the solo player.
# 0.5 means 50% of normal damage.
# Default: 0.5
SoloRaids.Naxxramas.Razuvious.UnbalancingStrike.DamagePct = 0.5

# Maximum active Guardian of Icecrown spawns during Kel'Thuzad in solo Naxxramas.
# Default: 2
SoloRaids.Naxxramas.KelThuzad.GuardianOfIcecrown.MaxActive = 2

#
# Karazhan
#

# Disable portal beam buffs on Netherspite in solo Karazhan.
# Player portal beam buffs and exhaustion remain unchanged.
# Default: 1
SoloRaids.Karazhan.Netherspite.DisablePortalBuffs = 1

#
# Magtheridon's Lair
#

# Allow one Manticron Cube channel to banish Magtheridon in solo Magtheridon's Lair.
# Default: 1
SoloRaids.MagtheridonsLair.Magtheridon.OneCubeBanish = 1

# Disable Hellfire Channelers' Burning Abyssal summon in solo Magtheridon's Lair.
# Default: 1
SoloRaids.MagtheridonsLair.Magtheridon.DisableBurningAbyssal = 1

#
# Gruul's Lair
#

# Blindeye the Seer's healing percentage in solo Gruul's Lair.
# 0.25 means 25% of normal healing.
# Default: 0.25
SoloRaids.GruulsLair.HighKingMaulgar.Blindeye.HealingPct = 0.25

# Maximum active felhounds summoned by Olm during High King Maulgar in solo Gruul's Lair.
# Default: 1
SoloRaids.GruulsLair.HighKingMaulgar.Olm.MaxFelhounds = 1

#
# Serpentshrine Cavern
#

# Disable Fathom-Guard Sharkkis's Leeching Throw during Fathom-Lord Karathress
# in solo Serpentshrine Cavern.
# Default: 1
SoloRaids.SerpentshrineCavern.FathomLordKarathress.DisableLeechingThrow = 1

# Disable Fathom-Guard Caribdis's Summon Cyclone during Fathom-Lord Karathress
# in solo Serpentshrine Cavern.
# Default: 1
SoloRaids.SerpentshrineCavern.FathomLordKarathress.DisableSummonCyclone = 1

# Morogrim Tidewalker's Tidal Wave debuff duration percentage in solo
# Serpentshrine Cavern. 0.25 means 25% of normal duration.
# Default: 0.25
SoloRaids.SerpentshrineCavern.MorogrimTidewalker.TidalWave.DurationPct = 0.25

# Disable Tainted Core's Paralyze effect in solo Serpentshrine Cavern.
# Default: 1
SoloRaids.SerpentshrineCavern.LadyVashj.DisableTaintedCoreParalyze = 1

# Prevent Tainted Elementals from despawning after 15 seconds during Lady Vashj
# in solo Serpentshrine Cavern.
# Default: 1
SoloRaids.SerpentshrineCavern.LadyVashj.PreventTaintedElementalDespawn = 1

# Maximum range in yards for Tainted Elemental's Poison Bolt during Lady Vashj
# in solo Serpentshrine Cavern.
# Default: 60
SoloRaids.SerpentshrineCavern.LadyVashj.TaintedElemental.PoisonBoltRange = 60

# Maximum active Enchanted Elementals during Lady Vashj in solo
# Serpentshrine Cavern.
# Default: 3
SoloRaids.SerpentshrineCavern.LadyVashj.EnchantedElemental.MaxActive = 3

# Minimum time in milliseconds between Toxic Sporebat summons during Lady
# Vashj in solo Serpentshrine Cavern.
# Default: 30000
SoloRaids.SerpentshrineCavern.LadyVashj.Sporebat.MinSpawnIntervalMs = 30000

#
# Tempest Keep
#

# Disable Master Engineer Telonicus's Remote Toy during Kael'thas Sunstrider
# in solo Tempest Keep.
# Default: 1
SoloRaids.TempestKeep.KaelthasSunstrider.DisableRemoteToy = 1

# Disable Infinity Blades' Thrash during Kael'thas Sunstrider in solo
# Tempest Keep.
# Default: 1
SoloRaids.TempestKeep.KaelthasSunstrider.DisableInfinityBladesThrash = 1

# Disable Devastation's Whirlwind during Kael'thas Sunstrider in solo
# Tempest Keep.
# Default: 1
SoloRaids.TempestKeep.KaelthasSunstrider.DisableDevastationWhirlwind = 1

#
# Mount Hyjal
#

# Damage percentage dealt by Mount Hyjal wave trash against all targets while
# the raid contains one player. 0.6 means 60% of normal damage.
# Default: 0.6
SoloRaids.MountHyjal.Trash.DamagePct = 0.6

# Disable Shadowy Necromancers' Raise Dead spells in solo Mount Hyjal.
# Default: 1
SoloRaids.MountHyjal.Trash.DisableRaiseDead = 1

# Disable Fel Stalkers' Mana Burn in solo Mount Hyjal.
# Default: 1
SoloRaids.MountHyjal.Trash.DisableManaBurn = 1

# Prevent Gargoyles from participating in waves in solo Mount Hyjal.
# Gargoyles are immediately removed while still satisfying the wave counter.
# Default: 1
SoloRaids.MountHyjal.Trash.PreventGargoyleSpawns = 1

# Mark of Kaz'rogal duration percentage in solo Mount Hyjal.
# 0.25 means 25% of normal duration.
# Default: 0.25
SoloRaids.MountHyjal.Kazrogal.Mark.DurationPct = 0.25

# Kaz'rogal's Cripple debuff duration percentage in solo Mount Hyjal.
# 0.5 means 50% of normal duration.
# Default: 0.5
SoloRaids.MountHyjal.Kazrogal.Cripple.DurationPct = 0.5

#
# Black Temple
#

# High Warlord Naj'entus's Tidal Shield duration percentage in solo Black
# Temple. 0.25 means 25% of normal duration.
# Default: 0.25
SoloRaids.BlackTemple.Najentus.TidalShield.DurationPct = 0.25

# Maximum Acidic Wound stacks during Gurtogg Bloodboil in solo Black Temple.
# Default: 10
SoloRaids.BlackTemple.GurtoggBloodboil.AcidicWound.MaxStacks = 10

# Disable Bewildering Strike during Gurtogg Bloodboil in solo Black Temple.
# Default: 1
SoloRaids.BlackTemple.GurtoggBloodboil.DisableBewilderingStrike = 1

# Disable Essence of Desire's Spirit Shock during Reliquary of Souls in solo
# Black Temple.
# Default: 1
SoloRaids.BlackTemple.ReliquaryOfSouls.EssenceOfDesire.DisableSpiritShock = 1

# Essence of Desire's Rune Shield duration percentage during Reliquary of
# Souls in solo Black Temple. 0.25 means 25% of normal duration.
# Default: 0.25
SoloRaids.BlackTemple.ReliquaryOfSouls.EssenceOfDesire.RuneShield.DurationPct = 0.25
